# Supabase Configuration
# Get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption
# All encryption is now client-side using the Web Crypto API (PBKDF2 + AES-GCM).
# No server-side encryption key is required. Each user's master key is derived in
# the browser from their password and a per-user key_salt stored in the users table.

# Issuer credential signing (server-custody Ed25519 keys)
# Required only for organizations that ISSUE credentials. AES-256-GCM-encrypts
# issuer private keys at rest. Must be a base64-encoded 32-byte (256-bit) key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ISSUER_KEY_SECRET=your-base64-32-byte-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# WebAuthn / Passkeys
NEXT_PUBLIC_RP_ID=localhost
# In production, set to your domain (e.g., luciddata.app)
