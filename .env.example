# Supabase Configuration
# Get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Encryption
# All encryption is now client-side using the Web Crypto API (PBKDF2 + AES-GCM).
# No server-side encryption key is required. Each user's master key is derived in
# the browser from their password and a per-user key_salt stored in the users table.

# Issuer credential signing (server-custody Ed25519 keys)
# Required only for organizations that ISSUE credentials. AES-256-GCM-encrypts
# issuer private keys at rest. Must be a base64-encoded 32-byte (256-bit) key.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ISSUER_KEY_SECRET=your-base64-32-byte-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# WebAuthn / Passkeys
NEXT_PUBLIC_RP_ID=localhost
# In production, set to your domain (e.g., luciddata.app)

# Email notifications (optional)
# In-app notifications always work. These configure the optional email copy sent
# through the EMAIL_TRANSPORT seam. Leave EMAIL_TRANSPORT unset to keep email a
# no-op (unless RESEND_API_KEY is set, which implies the "resend" transport).
#
#   console -> log the rendered email to the server console (local visibility)
#   smtp    -> send over SMTP (e.g. local Supabase Mailpit/Inbucket)
#   resend  -> deliver through Resend's HTTP API (recommended on serverless)
# EMAIL_TRANSPORT=console
#
# Sender shown on notification emails.
# NOTIFICATION_EMAIL_FROM=LucidData <noreply@luciddata.app>
#
# SMTP transport (EMAIL_TRANSPORT=smtp). Defaults target local Supabase Mailpit.
# Enable the SMTP port first by uncommenting smtp_port under [inbucket] in
# supabase/config.toml (default 54325), then run `npx supabase start`.
# EMAIL_SMTP_HOST=127.0.0.1
# EMAIL_SMTP_PORT=54325
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASS=
#
# Resend transport (EMAIL_TRANSPORT=resend). Server-only; never expose with NEXT_PUBLIC_.
# RESEND_API_KEY=your-resend-api-key

# Stripe billing (organization subscription plans).
# Test-mode keys: https://dashboard.stripe.com/test/apikeys . Server-only; never NEXT_PUBLIC_.
# STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for /api/stripe/webhook. Local dev:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring monthly price ids for the self-serve plans:
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_GROWTH=price_...
